```astro
---
import svgPinkStar from "../assets/pink-star.svg";
import Button from "./Button.astro";
import { buy } from "../sample";
---

<section class="px-3" id="contacto">
    <div class="max-w-3xl mx-auto bg-white text-center flex flex-col gap-4 border-3 shadow-[8px_8px_0px_var(--accent)] relative p-10">
        <h1 class="text-3xl font-semibold">Repositorio del proyecto</h1>
        <p class="text-lg max-w-lg mx-auto">
            Aquí encuentras todas las actividades, consultas SQL, diagramas E-R y ejercicios desarrollados durante el curso de <strong>Bases de Datos I</strong>.
        </p>
        <div class="flex justify-center">
            <Button text={buy.title} link={buy.link} target="_blank" />
        </div>
        <img src={svgPinkStar.src} alt="estrella" width="80" class="absolute -top-10 right-20" />
    </div>
</section>
```
