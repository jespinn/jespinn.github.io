```astro
---
import "../styles/global.css";
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";

import AppHeader from "./Header.astro";
import AppFooter from "./Footer.astro";
import CallToAction from "./CallToAction.astro";

const styleSheet = {
    actions: "text-gray-500 flex items-center gap-2 hover:text-gray-700 transition-colors",
};

const { frontmatter } = Astro.props;
const categoria = (frontmatter?.categoria || "evidencias") as keyof typeof rutasVolver;

const rutasVolver = {
    "modelo-er": { url: "/modelo-er/", texto: "Volver a Modelado E-R" },
    "fundamentos": { url: "/fundamentos/", texto: "Volver a Fundamentos" },
    "consultas-sql": { url: "/consultas-sql/", texto: "Volver a Consultas SQL" },
    "proyecto-final": { url: "/proyecto-final/", texto: "Volver a Proyecto Final" },
    "evidencias": { url: "/evidencias/", texto: "Volver a Evidencias" },
};

const volver = rutasVolver[categoria] || rutasVolver.evidencias;
---

<Layout title={frontmatter.title}>
    <AppHeader />

    <section class="py-20 px-4 md:px-6">
        <div class="max-w-4xl mx-auto bg-white rounded-lg shadow-[8px_8px_0px_var(--accent)] overflow-hidden border-3 border-black">
            <div class="p-6 md:p-10 lg:p-12">
                <a
                    href={volver.url}
                    class="inline-flex items-center gap-1 text-[var(--accent)] mb-6 transition-colors group hover:text-black"
                >
                    <span class="text-lg">←</span>
                    <span class="font-medium">{volver.texto}</span>
                </a>

                <div class="rounded-lg overflow-hidden border-2 border-black mb-8">
                    <Image
                        src={frontmatter.image.url}
                        alt={frontmatter.image.alt || frontmatter.title}
                        width={1200}
                        height={600}
                        class="w-full h-auto object-cover"
                    />
                </div>

                <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6 leading-tight">
                    {frontmatter.title}
                </h1>

                <div class="flex flex-col md:flex-row md:items-center justify-between border-t border-b border-gray-200 py-4 mb-8 gap-4">
                    <div class="flex gap-6">
                        <span class={styleSheet.actions}>
                            <i class="ri-calendar-line text-xl"></i>
                            <span>{frontmatter.pubDate}</span>
                        </span>
                        <span class={styleSheet.actions}>
                            <i class="ri-user-line text-xl"></i>
                            <span>{frontmatter.author?.name}</span>
                        </span>
                    </div>
                </div>

                <div class="prose prose-lg max-w-none">
                    <slot />
                </div>
            </div>
        </div>
    </section>

    <CallToAction />
    <AppFooter />
</Layout>
```