---
import Layout from "../../layouts/Layout.astro";
import AppHeader from "../../components/Header.astro";
import AppFooter from "../../components/Footer.astro";
import svgUnderline from "../../assets/underline.svg";
import arrowCard from "../../assets/arrow-card.svg";
---

<Layout title="Evidencias | Portafolio José Espin">
    <AppHeader />
    <section class="py-25 space-y-10 px-5" id="evidencias">
        <div class="max-w-md mx-auto relative">
            <h1 class="text-4xl font-medium text-center">Evidencias del curso</h1>
            <img src={svgUnderline.src} alt="línea" width="180" class="absolute left-30 -bottom-1" />
        </div>

        <p class="max-w-2xl mx-auto text-center opacity-80 text-lg">
            Selecciona una categoría para ver las actividades desarrolladas durante el semestre.
        </p>

        <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10">
            
                href="/modelo-er/"
                class="flex flex-col bg-white p-5 group relative transition-all duration-200 hover:shadow-[6px_6px_0px_var(--accent)] border-2 border-black"
            >
                <div class="w-full h-[200px] overflow-hidden border-2">
                    <img src="https://images.pexels.com/photos/590022/pexels-photo-590022.jpeg?auto=compress&cs=tinysrgb&w=1200" alt="Modelado E-R" class="w-full h-full object-cover" />
                </div>
                <div class="space-y-1 pt-4">
                    <div class="flex pr-2">
                        <h2 class="text-xl font-medium flex-1">Modelado E-R</h2>
                        <img src={arrowCard.src} alt="flecha" width="25" />
                    </div>
                    <p class="text-sm opacity-80">Diagramas Entidad-Relación que representan la estructura lógica de un sistema.</p>
                </div>
            </a>

            
                href="/fundamentos/"
                class="flex flex-col bg-white p-5 group relative transition-all duration-200 hover:shadow-[6px_6px_0px_var(--accent)] border-2 border-black"
            >
                <div class="w-full h-[200px] overflow-hidden border-2">
                    <img src="https://images.pexels.com/photos/669615/pexels-photo-669615.jpeg?auto=compress&cs=tinysrgb&w=1200" alt="Fundamentos" class="w-full h-full object-cover" />
                </div>
                <div class="space-y-1 pt-4">
                    <div class="flex pr-2">
                        <h2 class="text-xl font-medium flex-1">Fundamentos / Normalización</h2>
                        <img src={arrowCard.src} alt="flecha" width="25" />
                    </div>
                    <p class="text-sm opacity-80">Normalización (1FN, 2FN, 3FN) y reducción a tablas.</p>
                </div>
            </a>

            
                href="/consultas-sql/"
                class="flex flex-col bg-white p-5 group relative transition-all duration-200 hover:shadow-[6px_6px_0px_var(--accent)] border-2 border-black"
            >
                <div class="w-full h-[200px] overflow-hidden border-2">
                    <img src="https://images.pexels.com/photos/577585/pexels-photo-577585.jpeg?auto=compress&cs=tinysrgb&w=1200" alt="SQL" class="w-full h-full object-cover" />
                </div>
                <div class="space-y-1 pt-4">
                    <div class="flex pr-2">
                        <h2 class="text-xl font-medium flex-1">Consultas SQL</h2>
                        <img src={arrowCard.src} alt="flecha" width="25" />
                    </div>
                    <p class="text-sm opacity-80">SELECT, JOIN, WHERE, GROUP BY y subconsultas.</p>
                </div>
            </a>

            
                href="/proyecto-final/"
                class="flex flex-col bg-white p-5 group relative transition-all duration-200 hover:shadow-[6px_6px_0px_var(--accent)] border-2 border-black"
            >
                <div class="w-full h-[200px] overflow-hidden border-2">
                    <img src="https://images.pexels.com/photos/270348/pexels-photo-270348.jpeg?auto=compress&cs=tinysrgb&w=1200" alt="Proyecto" class="w-full h-full object-cover" />
                </div>
                <div class="space-y-1 pt-4">
                    <div class="flex pr-2">
                        <h2 class="text-xl font-medium flex-1">Proyecto Final</h2>
                        <img src={arrowCard.src} alt="flecha" width="25" />
                    </div>
                    <p class="text-sm opacity-80">Proyecto integrador del curso, documentado y publicado.</p>
                </div>
            </a>
        </div>
    </section>
    <AppFooter />
</Layout>