---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Evidencias | Portafolio de Bases de Datos">

<section class="px-3 py-20">
  <div class="max-w-5xl mx-auto">

    <h1 class="text-4xl md:text-5xl font-bold text-center mb-4">
      Evidencias del Portafolio
    </h1>

    <p class="text-center opacity-70 mb-12 text-lg">
      Modelado | Normalización | SQL | Proyecto Final
    </p>

    <div class="grid md:grid-cols-2 gap-8">

      <div class="bg-white border-3 p-8 shadow-[8px_8px_0px_rgba(0,0,0,0.3)] hover:-translate-y-1 transition border-black">
        <h2 class="text-2xl font-semibold mb-3">Modelado (ERD)</h2>
        <div class="w-full h-64 overflow-hidden border-2 border-black rounded mb-4">
          <img 
            src="/Ejercicio Aeropuerto BD1.png" 
            alt="Modelo ER Aeropuerto" 
            class="w-full h-full object-cover"
          />
        </div>
        <p class="opacity-80">
          Diseño de diagramas Entidad-Relación, definición de entidades, atributos (simples, compuestos, multivalorados) y cardinalidades.
        </p>
      </div>

      <div class="bg-white border-3 p-8 shadow-[8px_8px_0px_rgba(0,0,0,0.3)] hover:-translate-y-1 transition border-black">
        <h2 class="text-2xl font-semibold mb-3">Normalización</h2>
        <div class="w-full h-64 overflow-hidden border-2 border-black rounded mb-4">
          <img 
            src="/Ejercicio Hospital BD1.png" 
            alt="Normalización Hospital" 
            class="w-full h-full object-cover"
          />
        </div>
        <p class="opacity-80">
          Optimización de estructuras de datos mediante la aplicación de las Formas Normales (1FN, 2FN y 3FN).
        </p>
      </div>

      <div class="bg-white border-3 p-8 shadow-[8px_8px_0px_rgba(0,0,0,0.3)] hover:-translate-y-1 transition border-black">
        <h2 class="text-2xl font-semibold mb-3">Consultas SQL</h2>
        <div class="w-full h-64 overflow-hidden border-2 border-black rounded mb-4">
          <img 
            src="/Ejercicio Streaming BD1.png" 
            alt="Consultas SQL Streaming" 
            class="w-full h-full object-cover"
          />
        </div>
        <p class="opacity-80">
          Implementación de scripts DDL y DML: SELECT, JOIN complejos, agregaciones y gestión de subconsultas.
        </p>
      </div>

      <div class="bg-white border-3 p-8 shadow-[8px_8px_0px_rgba(0,0,0,0.3)] hover:-translate-y-1 transition border-black">
        <h2 class="text-2xl font-semibold mb-3">Proyecto Final</h2>
        <div class="w-full h-64 overflow-hidden border-2 border-black rounded mb-4">
          <img 
            src="/image_7e5c05.png" 
            alt="Componentes del Modelo ER" 
            class="w-full h-full object-contain bg-gray-50"
          />
        </div>
        <p class="opacity-80">
          Documentación técnica del portafolio desplegado con Astro y GitHub Pages.
        </p>
      </div>

    </div>
  </div>
</section>

</Layout>

<style>
  .card-img {
    background-position: center;
    background-size: cover;
  }
</style>